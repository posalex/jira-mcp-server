# =============================================================================
# Jira MCP Server + Firefox Cookie Extension — Configuration
# =============================================================================
# Copy this file to .env.local and adjust to match your environment:
#   cp .env.example .env.local
# =============================================================================

# --- Version -------------------------------------------------------------
VERSION=0.11.0

# --- Jira instance ------------------------------------------------------
# Full URL of your Jira instance (no trailing slash)
JIRA_URL=https://jira.example.com

# --- Cookie storage -----------------------------------------------------
# Path where cookies are persisted as JSON.
# Both the native-messaging host and the MCP server read/write this file.
COOKIE_FILE=$(HOME)/.jira-mcp-cookies.json

# --- Cookie names -------------------------------------------------------
# The session cookie name used by your Jira instance (usually JSESSIONID)
COOKIE_SESSION_NAME=JSESSIONID

# The XSRF cookie name (used for write operations like adding comments)
COOKIE_XSRF_NAME=atlassian.xsrf.token

# --- Bearer token fallback ----------------------------------------------
# Optional Personal Access Token used as a fallback when the session
# cookie is missing or expired. When set, both server.py and proxy.py
# will retry with `Authorization: Bearer <token>` if cookie auth fails.
# Generate one in Jira: Profile → Personal Access Tokens.
# BEARER_TOKEN=

# --- MCP server ----------------------------------------------------------
# Port for the cookie-manager web UI (built into server.py)
WEB_PORT=9777

# --- HTTP proxy (for IDE integrations like PhpStorm) ---------------------
# Port for the local reverse proxy
PROXY_PORT=9778

# Set to "false" to skip SSL verification (for self-signed certs)
PROXY_SSL_VERIFY=true

# Sanitize issue summaries for clean git branch names (strips special chars)
PROXY_SANITIZE_SUMMARIES=true

# Log full response bodies (verbose, for debugging only)
PROXY_LOG_RESPONSES=false

# --- Firefox extension ---------------------------------------------------
# A fixed extension ID (needed for native messaging allow-list)
EXTENSION_ID=jira-cookie-bridge@mcp-server

# --- Native messaging host -----------------------------------------------
# Name registered with Firefox (alphanumeric + dots, no dashes)
NATIVE_HOST_NAME=jira.cookie.bridge

# Absolute path to the native messaging host script.
# The Makefile will write this into the native-messaging-host manifest.
# Leave as-is to auto-detect based on the project directory.
NATIVE_HOST_PATH=$(shell pwd)/native-host/jira_cookie_bridge.py
